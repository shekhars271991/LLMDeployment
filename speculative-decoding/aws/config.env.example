# Copy to config.env, then fill local AWS values:
#   cp aws/config.env.example aws/config.env

export AWS_REGION="us-east-1"
export AWS_DEFAULT_REGION="${AWS_REGION}"

export INSTANCE_TYPE="g6e.xlarge"

# Region-specific Deep Learning Base OSS Nvidia Driver GPU AMI
export AMI_ID="ami-REPLACE_ME"

# Existing EC2 key-pair name and local private-key path
export KEY_NAME="REPLACE_ME"
export SSH_KEY_PATH="${HOME}/.ssh/${KEY_NAME}.pem"

# Security group in the selected VPC
export SG_ID="sg-REPLACE_ME"

# Leave empty to let EC2 choose a default subnet
export SUBNET_ID=""

export ROOT_VOLUME_GB=200
export INSTANCE_NAME_TAG="llm-deploy-qwen3-32b"
export SSH_USER="ubuntu"

# Runtime values are written to ignored aws/instance.env
export INSTANCE_ID=""
export INSTANCE_PUBLIC_IP=""
