# Copy to config.env before running Phase 2 remote scripts:
#   cp config.env.example config.env

export MODEL_ID="Qwen/Qwen3-32B-AWQ"
export SERVED_MODEL_NAME="qwen3-32b-awq"

export TP=1
CUDA_VISIBLE_DEVICES=""

export MAXLEN=16384
export GPU_MEM_UTIL=0.90
export PORT=8000

export HF_HOME="${HOME}/hf"
export VENV_DIR="${HOME}/vllm-venv"

NCCL_P2P_DISABLE=""
DISABLE_CUSTOM_ALL_REDUCE=""

# Phase 2 benchmark — deterministic greedy, fixed 256-token outputs
export BENCH_RUN_LABEL="control"
export BENCH_PROMPTS_FILE="speculative_prompts.json"
export BENCH_MAX_TOKENS=256
export BENCH_CONTEXT_LENGTHS="256,2048,8000"
export BENCH_API_BASE="http://127.0.0.1:8000/v1"
export BENCH_TEMPERATURE=0

# N-gram speculative decoding (serve_ngram_speculative.sh)
export NGRAM_NUM_SPEC_TOKENS=4
export NGRAM_PROMPT_LOOKUP_MIN=2
export NGRAM_PROMPT_LOOKUP_MAX=5

# Draft-model speculative decoding (serve_draft_speculative.sh)
export DRAFT_MODEL_ID="Qwen/Qwen3-0.6B"
export DRAFT_NUM_SPEC_TOKENS=5
export DRAFT_TP=1
