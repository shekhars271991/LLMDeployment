# AWS settings for llm-deploy (edit before running aws/ scripts)
# Run from repo root: source aws/config.env  OR  scripts source this file themselves.

# Region — us-east-1 / us-east-2 / us-west-2 recommended
export AWS_REGION="us-east-1"
export AWS_DEFAULT_REGION="${AWS_REGION}"

# Instance: g6e.xlarge (1x L40S 48GB, TP=1) or g6e.12xlarge (4x L40S, TP=2 with CUDA_VISIBLE_DEVICES)
export INSTANCE_TYPE="g6e.xlarge"

# Deep Learning OSS Nvidia Driver AMI (Ubuntu 22.04) — lookup in EC2 console for your region
# Example placeholder; replace with current AMI id for AWS_REGION
export AMI_ID="ami-xxxxxxxxxxxxxxxxx"

# SSH key pair name (created in EC2 console)
export KEY_NAME="your-key-name"

# Security group id (sg-...) — SSH port 22 from your IP only; do NOT open 8000
export SG_ID="sg-xxxxxxxxxxxxxxxxx"

# Optional subnet (leave empty to use default VPC subnet)
export SUBNET_ID=""

# Root volume size (GB) — model ~20GB + venv + HF cache
export ROOT_VOLUME_GB=200

# Tag for finding/terminating the instance
export INSTANCE_NAME_TAG="llm-deploy-qwen3-32b"

# Path to your .pem file (used by ssh_tunnel.sh)
export SSH_KEY_PATH="${HOME}/.ssh/${KEY_NAME}.pem"

# SSH user on Deep Learning AMI (Ubuntu)
export SSH_USER="ubuntu"

# Written by launch_instance.sh; used by ssh_tunnel.sh and terminate.sh
export INSTANCE_ID=""
export INSTANCE_PUBLIC_IP=""
