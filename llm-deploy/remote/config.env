# Remote vLLM settings (edit before running remote/ scripts on the EC2 box)
# Scripts source this file from the remote/ directory.

export MODEL_ID="Qwen/Qwen3-32B-AWQ"
export SERVED_MODEL_NAME="qwen3-32b-awq"

# Tensor parallel size: 1 for g6e.xlarge; 2 when using 2 GPUs on a 4-GPU box
export TP=1

# Pin GPUs on multi-GPU instances (e.g. g6e.12xlarge TP=2: export CUDA_VISIBLE_DEVICES=0,1)
# Leave empty to use all visible GPUs
export CUDA_VISIBLE_DEVICES=""

# Fixed baseline limits — keep constant across benchmark runs
export MAXLEN=16384
export GPU_MEM_UTIL=0.90
export PORT=8000

# Hugging Face cache (~20GB for AWQ weights)
export HF_HOME="${HOME}/hf"

# venv created by setup_venv.sh
export VENV_DIR="${HOME}/vllm-venv"

# NCCL workarounds for TP=2 on PCIe (no NVLink) — set to 1 if serve hangs at 100% GPU
export NCCL_P2P_DISABLE=""
export DISABLE_CUSTOM_ALL_REDUCE=""

# bench.py defaults
export BENCH_MAX_TOKENS=256
export BENCH_CONTEXT_LENGTHS="256,2048,8000"
export BENCH_API_BASE="http://127.0.0.1:${PORT}/v1"
