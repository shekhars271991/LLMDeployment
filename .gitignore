# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local venv (created on EC2 by setup_venv.sh)
vllm-venv/
.venv/
venv/
env/

# Hugging Face cache (large; created on remote box)
hf/
.cache/huggingface/

# Benchmark outputs (generated by bench.py / summarize.py)
llm-deploy/remote/results/*
!llm-deploy/remote/results/.gitkeep

# AWS runtime state (instance id / IP from launch_instance.sh)
llm-deploy/aws/instance.env

# Local configuration — templates (*.example) are tracked instead
llm-deploy/aws/config.env
llm-deploy/remote/config.env
**/config.local.env

# Secrets — never commit credentials, keys, or filled-in environment files
*.pem
*.key
.env
.env.*
!.env.example
*.tfvars
*.tfstate
*.tfstate.*

# Logs
*.log
llm-deploy/records/
llm-deploy/remote/records/
