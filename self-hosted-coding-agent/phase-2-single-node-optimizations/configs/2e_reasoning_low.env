# configs/2e_reasoning_low.env
# Phase 2e lever: reasoning OFF (a request-time lever, not a serve flag).
# CHANGED vs 2a_fp8_baseline: ENABLE_THINKING="false".
# Goal: quantify the reasoning trade — quality vs cost/latency. Reasoning inflates output 2-10x,
# so turning it off should slash tokens/task + latency; measure how much SWE-bench quality it costs.
# The server is served identically to the baseline; 03_run_benchmark.sh injects
# chat_template_kwargs {enable_thinking: false} at request time.
# NOTE: confirm how mini-swe-agent/litellm forwards chat_template_kwargs for the installed versions.

CONFIG_NAME="2e_reasoning_low"
SUBPHASE="2e"

ENGINE="vllm"

MODEL_ID="Qwen/Qwen3.6-35B-A3B-FP8"
SERVED_MODEL_NAME="qwen3.6-35b-a3b-fp8"

MAXLEN=32768
GPU_MEM_UTIL=0.92
KV_CACHE_DTYPE=""

ENABLE_PREFIX_CACHING=1
ENABLE_CHUNKED_PREFILL=0
MAX_NUM_BATCHED_TOKENS=""

MAX_NUM_SEQS=16
ENFORCE_EAGER=0
COMPILATION_LEVEL=""

SPEC_CONFIG=""

# The lever for this sub-phase: turn thinking OFF at request time.
ENABLE_THINKING="false"

EXTRA_SERVE_ARGS=""

SUBSET="lite"
SPLIT="test"
INSTANCE_LIMIT="5"
WORKERS="4"
MAX_MODEL_TOKENS="64000"
