# configs/2d_spec_mtp.env
# Phase 2d lever: native MTP speculative decoding.
# CHANGED vs 2a_fp8_baseline: SPEC_CONFIG set to Qwen's native multi-token-prediction head.
# Goal: speed up decode (dominant here because reasoning makes decode long). Measure decode
# speedup at FIXED quality (spec decoding must be lossless — verify resolve rate is unchanged).
# NOTE: confirm the method name ("qwen3_next_mtp") + schema against the installed vLLM.

CONFIG_NAME="2d_spec_mtp"
SUBPHASE="2d"

ENGINE="vllm"

MODEL_ID="Qwen/Qwen3.6-35B-A3B-FP8"
SERVED_MODEL_NAME="qwen3.6-35b-a3b-fp8"

MAXLEN=32768
GPU_MEM_UTIL=0.92
KV_CACHE_DTYPE=""

ENABLE_PREFIX_CACHING=1
ENABLE_CHUNKED_PREFILL=0
MAX_NUM_BATCHED_TOKENS=""

MAX_NUM_SEQS=16
ENFORCE_EAGER=0
COMPILATION_LEVEL=""

# Native multi-token-prediction (MTP) draft head shipped with the model.
SPEC_CONFIG='{"method": "qwen3_next_mtp", "num_speculative_tokens": 2}'

ENABLE_THINKING=""

EXTRA_SERVE_ARGS=""

SUBSET="lite"
SPLIT="test"
INSTANCE_LIMIT="5"
WORKERS="4"
MAX_MODEL_TOKENS="64000"
