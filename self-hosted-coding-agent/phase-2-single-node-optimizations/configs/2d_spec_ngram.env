# configs/2d_spec_ngram.env
# Phase 2d lever (alternative): n-gram / prompt-lookup speculative decoding.
# CHANGED vs 2a_fp8_baseline: SPEC_CONFIG set to the n-gram method.
# Goal: cheap, model-free decode speedup that shines when output echoes the prompt (code edits,
# diffs, repeated identifiers). A/B against 2d_spec_mtp. Measure decode speedup at FIXED quality.
# NOTE: confirm the ngram schema (num_speculative_tokens / prompt_lookup_min/max) for the vLLM version.

CONFIG_NAME="2d_spec_ngram"
SUBPHASE="2d"

ENGINE="vllm"

MODEL_ID="Qwen/Qwen3.6-35B-A3B-FP8"
SERVED_MODEL_NAME="qwen3.6-35b-a3b-fp8"

MAXLEN=32768
GPU_MEM_UTIL=0.92
KV_CACHE_DTYPE=""

ENABLE_PREFIX_CACHING=1
ENABLE_CHUNKED_PREFILL=0
MAX_NUM_BATCHED_TOKENS=""

MAX_NUM_SEQS=16
ENFORCE_EAGER=0
COMPILATION_LEVEL=""

SPEC_CONFIG='{"method": "ngram", "num_speculative_tokens": 4, "prompt_lookup_min": 2, "prompt_lookup_max": 5}'

ENABLE_THINKING=""

EXTRA_SERVE_ARGS=""

SUBSET="lite"
SPLIT="test"
INSTANCE_LIMIT="5"
WORKERS="4"
MAX_MODEL_TOKENS="64000"
