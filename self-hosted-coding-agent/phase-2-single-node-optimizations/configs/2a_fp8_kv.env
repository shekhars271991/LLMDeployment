# configs/2a_fp8_kv.env
# Phase 2a lever: FP8 KV cache on top of the FP8-weights baseline.
# CHANGED vs 2a_fp8_baseline: KV_CACHE_DTYPE="fp8" (+ larger MAXLEN it buys).
# Goal: quantify KV/context gained vs any quality delta (re-run SWE-bench, don't assume parity).

CONFIG_NAME="2a_fp8_kv"
SUBPHASE="2a"

ENGINE="vllm"

MODEL_ID="Qwen/Qwen3.6-35B-A3B-FP8"
SERVED_MODEL_NAME="qwen3.6-35b-a3b-fp8"

# FP8 KV halves KV footprint -> spend it on more context.
MAXLEN=65536
GPU_MEM_UTIL=0.92
KV_CACHE_DTYPE="fp8"

ENABLE_PREFIX_CACHING=1
ENABLE_CHUNKED_PREFILL=0
MAX_NUM_BATCHED_TOKENS=""

MAX_NUM_SEQS=16
ENFORCE_EAGER=0
COMPILATION_LEVEL=""

SPEC_CONFIG=""

ENABLE_THINKING=""

EXTRA_SERVE_ARGS=""

SUBSET="lite"
SPLIT="test"
INSTANCE_LIMIT="5"
WORKERS="4"
MAX_MODEL_TOKENS="64000"
