# configs/2f_sglang.env
# Phase 2f lever: serving engine A/B — SGLang instead of vLLM.
# CHANGED vs 2a_fp8_baseline: ENGINE="sglang".
# Goal: test whether SGLang's RadixAttention (token-level prefix tree) beats vLLM on the long,
# stable coding prefix. Both expose OpenAI /v1 so the harness/client stay identical.
# Measure prefill latency, prefix hit rate, capacity. Keep every other lever at the baseline so
# the delta is purely engine. (Triton/TensorRT-LLM deferred — AOT compile kills experiment velocity.)
# NOTE: confirm SGLang's reasoning/tool-parser flag names for the installed version (02_serve.sh).

CONFIG_NAME="2f_sglang"
SUBPHASE="2f"

ENGINE="sglang"

MODEL_ID="Qwen/Qwen3.6-35B-A3B-FP8"
SERVED_MODEL_NAME="qwen3.6-35b-a3b-fp8"

MAXLEN=32768
GPU_MEM_UTIL=0.92
KV_CACHE_DTYPE=""

# RadixAttention (SGLang's prefix cache) is ON by default; kept here for parity/intent.
ENABLE_PREFIX_CACHING=1
ENABLE_CHUNKED_PREFILL=0
MAX_NUM_BATCHED_TOKENS=""

MAX_NUM_SEQS=16
ENFORCE_EAGER=0
COMPILATION_LEVEL=""

SPEC_CONFIG=""

ENABLE_THINKING=""

EXTRA_SERVE_ARGS=""

SUBSET="lite"
SPLIT="test"
INSTANCE_LIMIT="5"
WORKERS="4"
MAX_MODEL_TOKENS="64000"
