# configs/2b_prefix_chunked.env
# Phase 2b lever: chunked prefill + longer context on top of prefix caching.
# CHANGED vs 2a_fp8_baseline: ENABLE_CHUNKED_PREFILL=1, MAX_NUM_BATCHED_TOKENS set, larger MAXLEN.
# Goal: exploit the shared agentic prefix (system prompt + tool schema replayed every turn)
# and keep long prompts from stalling decode. Measure TTFT win on shared prefixes + long-prompt
# behavior under concurrency. (Prefix caching is already ON in the baseline.)

CONFIG_NAME="2b_prefix_chunked"
SUBPHASE="2b"

ENGINE="vllm"

MODEL_ID="Qwen/Qwen3.6-35B-A3B-FP8"
SERVED_MODEL_NAME="qwen3.6-35b-a3b-fp8"

# Tune to real codebase sizes; longer context is the point of this sub-phase.
MAXLEN=49152
GPU_MEM_UTIL=0.92
KV_CACHE_DTYPE=""

ENABLE_PREFIX_CACHING=1
ENABLE_CHUNKED_PREFILL=1
# Chunk long prefills so they interleave with decode instead of blocking it.
MAX_NUM_BATCHED_TOKENS="2048"

MAX_NUM_SEQS=16
ENFORCE_EAGER=0
COMPILATION_LEVEL=""

SPEC_CONFIG=""

ENABLE_THINKING=""

EXTRA_SERVE_ARGS=""

SUBSET="lite"
SPLIT="test"
INSTANCE_LIMIT="5"
WORKERS="4"
MAX_MODEL_TOKENS="64000"
