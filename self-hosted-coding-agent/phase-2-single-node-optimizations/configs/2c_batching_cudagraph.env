# configs/2c_batching_cudagraph.env
# Phase 2c lever: raise batching + lock in CUDA graphs / torch.compile.
# CHANGED vs 2a_fp8_baseline: higher MAX_NUM_SEQS + MAX_NUM_BATCHED_TOKENS, COMPILATION_LEVEL=3.
# Goal: raise throughput without breaking latency; cut per-decode-step overhead.
# Measure throughput/latency vs --max-num-seqs and scheduler settings.
# NOTE: CUDA graphs are ON by default (ENFORCE_EAGER=0); set ENFORCE_EAGER=1 for the A/B baseline.

CONFIG_NAME="2c_batching_cudagraph"
SUBPHASE="2c"

ENGINE="vllm"

MODEL_ID="Qwen/Qwen3.6-35B-A3B-FP8"
SERVED_MODEL_NAME="qwen3.6-35b-a3b-fp8"

MAXLEN=32768
GPU_MEM_UTIL=0.92
KV_CACHE_DTYPE=""

ENABLE_PREFIX_CACHING=1
ENABLE_CHUNKED_PREFILL=0
MAX_NUM_BATCHED_TOKENS="8192"

# Push concurrency higher and let vLLM compile (-O3) + capture CUDA graphs.
MAX_NUM_SEQS=64
ENFORCE_EAGER=0
COMPILATION_LEVEL="3"

SPEC_CONFIG=""

ENABLE_THINKING=""

EXTRA_SERVE_ARGS=""

SUBSET="lite"
SPLIT="test"
INSTANCE_LIMIT="5"
WORKERS="8"
MAX_MODEL_TOKENS="64000"
