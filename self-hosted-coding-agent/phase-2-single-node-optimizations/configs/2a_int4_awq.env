# configs/2a_int4_awq.env
# Phase 2a lever: AWQ INT4 weights instead of FP8.
# CHANGED vs 2a_fp8_baseline: MODEL_ID/SERVED_MODEL_NAME -> AWQ INT4 (+ larger MAXLEN it buys).
# Goal: INT4 frees ~2x the KV headroom; measure whether SWE-bench quality holds vs FP8.
# NOTE: confirm the exact community AWQ repo name/availability before running (reference.md §2.3).

CONFIG_NAME="2a_int4_awq"
SUBPHASE="2a"

ENGINE="vllm"

MODEL_ID="QuantTrio/Qwen3.6-35B-A3B-AWQ"
SERVED_MODEL_NAME="qwen3.6-35b-a3b-awq"

# INT4 weights (~18-20GB) leave ~2x the KV room vs FP8 -> much longer context.
MAXLEN=98304
GPU_MEM_UTIL=0.92
KV_CACHE_DTYPE=""

ENABLE_PREFIX_CACHING=1
ENABLE_CHUNKED_PREFILL=0
MAX_NUM_BATCHED_TOKENS=""

MAX_NUM_SEQS=16
ENFORCE_EAGER=0
COMPILATION_LEVEL=""

SPEC_CONFIG=""

ENABLE_THINKING=""

EXTRA_SERVE_ARGS=""

SUBSET="lite"
SPLIT="test"
INSTANCE_LIMIT="5"
WORKERS="4"
MAX_MODEL_TOKENS="64000"
