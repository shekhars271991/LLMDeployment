# configs/2a_fp8_baseline.env
# ============================================================================
# Phase 2 SWEEP BASELINE — the inherited Phase 1 "winning" single-node config.
#
# Every other config in this folder changes EXACTLY ONE lever vs this file, so
# the per-sub-phase delta is attributable to that one lever (see PLAN §3.7).
# 02_serve.sh sources one of these files (CONFIG=... ) and builds the serve
# command from it; 03_run_benchmark.sh reads the benchmark-side levers.
#
# This is the reference every 2a–2f run is compared against. Copy this file to
# create a new variant, then change one line.
# ============================================================================

# --- identity (shows up in record filenames + the compare table) ---
CONFIG_NAME="2a_fp8_baseline"
SUBPHASE="2a"

# --- engine: vllm | sglang (sglang is only used by 2f) ---
ENGINE="vllm"

# --- model / precision (the 2a lever) ---
MODEL_ID="Qwen/Qwen3.6-35B-A3B-FP8"
SERVED_MODEL_NAME="qwen3.6-35b-a3b-fp8"

# --- KV / context budget ---
MAXLEN=32768
GPU_MEM_UTIL=0.92
# KV cache dtype: "" = engine default (matches weights); "fp8" = FP8 KV cache (2a lever).
KV_CACHE_DTYPE=""

# --- prefix caching + chunked prefill (the 2b levers) ---
ENABLE_PREFIX_CACHING=1
ENABLE_CHUNKED_PREFILL=0
# Empty = engine default. Raise for chunked-prefill / throughput experiments (2c).
MAX_NUM_BATCHED_TOKENS=""

# --- batching / scheduler + CUDA graphs (the 2c levers) ---
MAX_NUM_SEQS=16
# vLLM captures CUDA graphs by default. ENFORCE_EAGER=1 disables them (slower,
# used only to A/B the graph-capture win). torch.compile level: ""=default, 3 -> -O3.
ENFORCE_EAGER=0
COMPILATION_LEVEL=""

# --- speculative decoding (the 2d lever) ---
# Empty = OFF. A JSON string here is passed verbatim to --speculative-config.
SPEC_CONFIG=""

# --- reasoning (baseline = ON; 2e sweeps this) ---
# "" = model default (thinking ON). "false" = reasoning OFF via
# chat_template_kwargs {enable_thinking: false} at request time (2e lever).
ENABLE_THINKING=""

# --- freeform escape hatch for any extra serve flags (space-separated) ---
EXTRA_SERVE_ARGS=""

# --- benchmark-side knobs (read by 03_run_benchmark.sh) ---
# `lite` for fast iteration while wiring a lever; `verified` for the headline delta.
SUBSET="lite"
SPLIT="test"
INSTANCE_LIMIT="5"        # small smoke slice; empty or 0 = full subset
WORKERS="4"
MAX_MODEL_TOKENS="64000"
